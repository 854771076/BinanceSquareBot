# BinanceSquareBot 配置示例
# 复制此文件为 .env 并填入实际配置值

# ============================================
# 全局配置
# ============================================

SQLITE_DB_PATH=data/app.db
LOG_LEVEL=INFO

# LLM 配置
LLM_API_KEY=your-openai-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 生成参数
MAX_RETRIES=3
MIN_CHARS=101
MAX_CHARS=799
MAX_HASHTAGS=2
MAX_MENTIONS=2

# ============================================
# FnSource 配置 (新闻源)
# 环境变量命名: FN_SOURCE_<FIELD_NAME>
# ============================================

FN_SOURCE_ENABLED=true
FN_SOURCE_DAILY_MAX_EXECUTIONS=30
FN_SOURCE_BASE_URL=https://api.foresightnews.pro
FN_SOURCE_TIMEOUT=30

# ============================================
# PolymarketSource 配置 (预测市场研报源)
# 环境变量命名: POLYMARKET_SOURCE_<FIELD_NAME>
# ============================================

POLYMARKET_SOURCE_ENABLED=true
POLYMARKET_SOURCE_DAILY_MAX_EXECUTIONS=10
POLYMARKET_SOURCE_HOST=https://clob.polymarket.com
POLYMARKET_SOURCE_MIN_VOLUME_THRESHOLD=1000.0
POLYMARKET_SOURCE_MIN_WIN_RATE=0.6
POLYMARKET_SOURCE_MAX_WIN_RATE=0.95

# ============================================
# FollowinSource 配置 (Followin热点/币种源)
# 环境变量命名: FOLLOWIN_SOURCE_<FIELD_NAME>
# ============================================

FOLLOWIN_SOURCE_ENABLED=true
FOLLOWIN_SOURCE_DAILY_MAX_EXECUTIONS=24
FOLLOWIN_SOURCE_BASE_URL=https://api.followin.io
FOLLOWIN_SOURCE_WEB_BASE_URL=https://followin.io
FOLLOWIN_SOURCE_TIMEOUT=30
FOLLOWIN_SOURCE_MAX_ITEMS_PER_CATEGORY=2
FOLLOWIN_SOURCE_GTOKEN=your-followin-gtoken-here

# ============================================
# BinanceTarget 配置 (币安广场发布目标)
# 环境变量命名: BINANCE_TARGET_<FIELD_NAME>
# ============================================

BINANCE_TARGET_ENABLED=true
BINANCE_TARGET_DAILY_MAX_POSTS_PER_KEY=100
# 多个 API Key 用逗号分隔
BINANCE_TARGET_API_KEYS=your-first-api-key,your-second-api-key
BINANCE_TARGET_API_URL=https://www.binance.com/bapi/composite/v1/public/pgc/openApi/content/add
BINANCE_TARGET_STOP_WORDS=bitget,okx
